APP_NAME=MedZiva
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://medzivahealthcare.com
FRONTEND_URL=https://medzivahealthcare.com
CLIENT_ORIGIN=https://medzivahealthcare.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Asia/Dubai

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=medziva
DB_USERNAME=medziva
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtpout.secureserver.net
MAIL_PORT=465
MAIL_USERNAME=booking@medzivahealthcare.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=booking@medzivahealthcare.com
MAIL_FROM_NAME="MedZiva Healthcare"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=medzivahealthcare.com,localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:5173

GOOGLE_CLIENT_ID=
GOOGLE_ADMIN_EMAILS=

ENBDPAY_BASE_URL=https://enbduat-acquiring-apigw.creditpluspinelabs.com
ENBDPAY_USERNAME=
ENBDPAY_API_KEY=
ENBDPAY_CURRENCY=AED
ENBDPAY_PAYMENT_METHOD=CARD
ENBDPAY_TRANSACTION_TYPE=AUTH
ENBDPAY_REDIRECT_URL=
ENBDPAY_WEBHOOK_URL=
ENBDPAY_WEBHOOK_SECRET=
ENBDPAY_MOCK=true

PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
PUSHER_USE_TLS=true
PUSHER_CHANNEL=medziva-notifications

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
